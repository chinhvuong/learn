# ===========================================
# Inflow Backend — Environment Variables
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Port convention: Inflow uses the 810x prefix for every external port
# (host-side when running under docker, direct when running locally).

# ===========================================
# Application Configuration
# ===========================================
NODE_ENV=development
SERVICE_TYPE=all
# Options: api, worker, all

# Server Ports (host-side under docker; bind port when running locally)
API_PORT=8200
WORKER_PORT=8101
WORKER_CONCURRENCY=4

# ===========================================
# Database Configuration (PostgreSQL)
# ===========================================
DATABASE_HOST=localhost
DATABASE_PORT=8102
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=inflow
DATABASE_LOGGING=false

# ===========================================
# Redis Configuration (used by BullMQ + cache)
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=8103
REDIS_PASSWORD=
REDIS_URL=redis://localhost:8103

# ===========================================
# BullMQ Configuration
# ===========================================
# Namespace prefix for BullMQ keys in Redis. Override per-env when multiple
# Inflow environments share a single Redis instance (`inflow-staging`, etc).
BULLMQ_PREFIX=inflow

# ===========================================
# Bull Board (queue dashboard)
# ===========================================
# Mounted on the API server at `${global-prefix}${BULLBOARD_PATH}` when enabled.
# Default URL: http://localhost:${API_PORT}/api/admin/queues
BULLBOARD_ENABLED=true
BULLBOARD_PATH=/admin/queues
BULLBOARD_USERNAME=admin
# REQUIRED when BULLBOARD_ENABLED=true. App fails to boot if empty — no
# default credential is shipped intentionally.
BULLBOARD_PASSWORD=change-me-locally

# ===========================================
# Demo module (BullMQ smoke test)
# ===========================================
# Mounts POST /api/v1/demo/ping + the demo.ping queue. Reference template for
# how feature modules should split into shared / api / worker sub-modules.
# Disable in production once a real feature follows the same pattern.
DEMO_ENABLED=true

# ===========================================
# JWT Configuration
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ===========================================
# Cache Configuration
# ===========================================
TYPEORM_CACHE_ENABLED=true
TYPEORM_CACHE_TTL_MULTIPLIER=1
HTTP_CACHE_ENABLED=true
BROWSER_CACHE_ENABLED=true
CDN_CACHE_ENABLED=true

# ===========================================
# Firebase Auth (Admin SDK)
# ===========================================
# Project ID for the Firebase project hosting the apps.
FIREBASE_PROJECT_ID=inflow-dev
# Service-account credential for the Admin SDK. Four wire forms, auto-detected
# from the value shape. Default is base64 so local dev exercises the same
# code path as deployed environments.
#
#   Form A — base64 (canonical, used in every environment). Generate from
#   the service-account JSON with:
#     yarn firebase:base64                       # macOS — encodes firebase-admin-dev.json → clipboard
#     openssl base64 -A < firebase-admin.json    # any host
#     cat firebase-admin.json | base64 -w0       # GNU/Linux
#     cat firebase-admin.json | base64 | tr -d '\n'   # macOS bsd base64
FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi...PASTE_FULL_BASE64_HERE
#
#   Form B — local path to a JSON file (alternative; useful for hot-reloading
#   a freshly-rotated key without re-encoding). File path is relative to
#   backend/ or absolute. File is gitignored.
# FIREBASE_SERVICE_ACCOUNT_JSON=./firebase-admin-dev.json
#
#   Form C — inline JSON. Technically supported; avoid in practice because
#   the private_key PEM newlines are fragile through env-var pipelines.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
#   Form D — Google Application Default Credentials (the literal "adc").
#   Use when running on a GCP host that exposes a metadata server.
# FIREBASE_SERVICE_ACCOUNT_JSON=adc

# ===========================================
# Object Storage (Cloudflare R2, S3-compatible)
# ===========================================
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ACCOUNT_ID=
R2_BUCKET_NAME=inflow-dev
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
# Set to the r2.dev subdomain shown in Cloudflare dashboard once the bucket is
# marked public (Settings → Public Access → Allow r2.dev).
R2_PUBLIC_URL_BASE=https://pub-xxx.r2.dev
